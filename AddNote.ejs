<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NOTE ADD FROM HERE</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <div class="container">
        <h1>Add a note ✍️</h1>
        <a class="btn" href="/homePage">⬅️ Back to Home</a> <!-- IT SEND TO THE MAIN HOME PAGE -->

        <form action="/AddNote" method="post">
